# Root .htaccess — redirect all traffic to /public_html
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve requests that already point inside /public_html directly
    RewriteRule ^public_html/(.*)$ public_html/$1 [L]

    # Everything else → public_html/
    RewriteCond %{REQUEST_URI} !^/public_html
    RewriteRule ^(.*)$ public_html/$1 [L]
</IfModule>
